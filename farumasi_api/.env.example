# ─────────────────────────────────────────────
#  FARUMASI API – Environment Configuration
# ─────────────────────────────────────────────

# Application
APP_NAME="FARUMASI API"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql://farumasi:farumasi_pass@localhost:5432/farumasi_db
ASYNC_DATABASE_URL=postgresql+asyncpg://farumasi:farumasi_pass@localhost:5432/farumasi_db

# JWT Security
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=90

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3005,http://localhost:8080,http://127.0.0.1:8080

# Redis
REDIS_URL=redis://localhost:6379

# Platform Commission (0.10 = 10%)
PLATFORM_COMMISSION_RATE=0.10

# Email — Brevo (OTP registration, password reset, payout verification)
#
# Render free tier blocks SMTP port 587 — use BREVO_API_KEY (HTTP, recommended).
# Local dev can use either BREVO_API_KEY or SMTP below.
#
# Brevo → SMTP & API → API Keys → create key (permission: send transactional emails)
# Brevo → Senders → verify SMTP_FROM_EMAIL
BREVO_API_KEY=
SMTP_FROM_EMAIL=noreply@farumasi.com
SMTP_FROM_NAME=FARUMASI
EMAIL_VERIFICATION_EXPIRE_MINUTES=10

# Optional SMTP fallback (works locally; blocked on Render free tier)
# Brevo → SMTP & API → SMTP: Login (…@smtp-brevo.com) + xsmtpsib-… key
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# Patient payments — sandbox auto-confirms in development; live uses Pesapal checkout
PAYMENT_MODE=sandbox
PAYMENT_CURRENCY=RWF
PAYMENT_PROCESSING_FEE_PERCENT=3.5
PESAPAL_ENV=sandbox
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
# After API is public: python scripts/register_pesapal_ipn.py --url https://YOUR-API/api/v1/webhooks/pesapal
PESAPAL_IPN_ID=
PESAPAL_IPN_URL=
API_PUBLIC_URL=http://localhost:8000
PATIENT_PORTAL_URL=http://localhost:3002

# MTN MoMo Collection (recommended for MTN — phone prompt, no Pesapal card form)
# https://momodeveloper.mtn.com
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
MTN_MOMO_ENV=sandbox
MTN_MOMO_CURRENCY=RWF
MTN_MOMO_TARGET_ENVIRONMENT=sandbox
MTN_MOMO_CALLBACK_URL=

# Google Sign-In (Flutter) — OAuth 2.0 Web client ID from Google Cloud Console
GOOGLE_WEB_CLIENT_ID=
# Optional Supabase (storage / legacy flows)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# File Storage: local | s3 | cloudinary
# IMPORTANT (Render/production): local files are deleted on every redeploy.
# Set CLOUDINARY_* below (recommended) — the API auto-uses Cloudinary when creds exist.
STORAGE_BACKEND=local
UPLOAD_DIR=uploads

# AWS S3 (only needed when STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=us-east-1
AWS_S3_ENDPOINT_URL=

# Cloudinary (only needed when STORAGE_BACKEND=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Firebase Cloud Messaging — instant push when the app is killed
# Create a Firebase project → Project settings → Service accounts → Generate new private key.
# Paste the full JSON on one line, or base64-encode it for Render env vars.
FCM_ENABLED=true
FIREBASE_SERVICE_ACCOUNT_JSON=
