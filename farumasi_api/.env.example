# ─────────────────────────────────────────────
#  FARUMASI API – Environment Configuration
# ─────────────────────────────────────────────

# Application
APP_NAME="FARUMASI API"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql://farumasi:farumasi_pass@localhost:5432/farumasi_db
ASYNC_DATABASE_URL=postgresql+asyncpg://farumasi:farumasi_pass@localhost:5432/farumasi_db

# JWT Security
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3005,http://localhost:8080,http://127.0.0.1:8080

# Redis
REDIS_URL=redis://localhost:6379

# Platform Commission (0.10 = 10%)
PLATFORM_COMMISSION_RATE=0.10

# Email verification (payout credential changes). Leave SMTP_HOST empty to log codes in dev.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@farumasi.com
SMTP_USE_TLS=true
EMAIL_VERIFICATION_EXPIRE_MINUTES=10

# Patient payments — sandbox auto-confirms in development; live uses Pesapal checkout
PAYMENT_MODE=sandbox
PAYMENT_CURRENCY=RWF
PESAPAL_ENV=sandbox
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
# After API is public: python scripts/register_pesapal_ipn.py --url https://YOUR-API/api/v1/webhooks/pesapal
PESAPAL_IPN_ID=
PESAPAL_IPN_URL=
API_PUBLIC_URL=http://localhost:8000
PATIENT_PORTAL_URL=http://localhost:3002

# File Storage: local | s3 | cloudinary
STORAGE_BACKEND=local
UPLOAD_DIR=uploads

# AWS S3 (only needed when STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=us-east-1
AWS_S3_ENDPOINT_URL=

# Cloudinary (only needed when STORAGE_BACKEND=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
