# Farumasi Patient Portal — environment template
# Copy to .env.local and adjust as needed. Do NOT commit secrets.

# Backend API base URL (FastAPI, with /api/v1 prefix)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Set to "true" to use local mock data, "false" to hit the real backend.
NEXT_PUBLIC_USE_MOCK=false

# Google Sign-In (Web OAuth client ID) — or set GOOGLE_WEB_CLIENT_ID on the API
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
